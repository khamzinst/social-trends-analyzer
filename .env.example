# =====================================================
# TrendScope — файл переменных окружения
# Скопируйте этот файл в .env и заполните значения
# =====================================================

# База данных PostgreSQL
# Формат: postgresql://ПОЛЬЗОВАТЕЛЬ:ПАРОЛЬ@ХОСТ:ПОРТ/БАЗА_ДАННЫХ
DATABASE_URL="postgresql://postgres:password@localhost:5432/social_trends_db"

# Секретный ключ для JWT (минимум 32 символа)
# Сгенерируйте: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="super-secret-key-change-this-in-production-minimum-32-chars"

# URL приложения
NEXT_PUBLIC_APP_URL="http://localhost:3000"
